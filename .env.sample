# ===== Whisper モデル設定 =====

# 使用するWhisperモデル（tiny / base / small / medium / large-v3）
WHISPER_MODEL=large-v3

# 実行デバイス（cuda / cpu）
WHISPER_DEVICE=cuda

# 量子化タイプ（float16 / int8 / float32）※cudaはfloat16推奨、cpuはint8推奨
WHISPER_COMPUTE_TYPE=float16

# CPUスレッド数（0=自動）
WHISPER_CPU_THREADS=0

# 並列デコードワーカー数
WHISPER_NUM_WORKERS=1

# ビームサーチ幅（大きいほど精度↑・速度↓）
WHISPER_BEAM_SIZE=10

# サンプリング候補数（複数候補からベストを選択、精度↑）
WHISPER_BEST_OF=5

# 認識言語
WHISPER_LANGUAGE=ja

# VADフィルター（無音区間除去・幻覚抑制）
WHISPER_VAD_FILTER=true

# VAD詳細設定
# 音声判定の確信度閾値（高いほど厳しく判定）
WHISPER_VAD_THRESHOLD=0.5
# 最小音声長（ミリ秒）※これより短い音はノイズとして除外
WHISPER_VAD_MIN_SPEECH_MS=250
# 最小無音長（ミリ秒）※これ以上の無音でセグメント区切り＝改行位置に影響
WHISPER_VAD_MIN_SILENCE_MS=2000

# 前セグメントを文脈として使用（falseで幻覚抑制）
WHISPER_CONDITION_ON_PREVIOUS_TEXT=false

# サンプリング温度（0.0=決定的）
WHISPER_TEMPERATURE=0.0

# 無音判定の確信度閾値
WHISPER_NO_SPEECH_THRESHOLD=0.6

# ===== プロンプト設定 =====

# 用語集プロンプトファイルパス（空の場合 ROOT_DIR/prompt.txt を使用）
# bundle時は %APPDATA%\voice-paste\prompt.txt が既定
PROMPT_FILE=

# 誤変換修正用の用語集CSVファイルパス（カラム: 誤変換, 正しい表記）
# bundle時は %APPDATA%\voice-paste\yogo.csv が既定
YOGO_FILE=

# ===== 動作設定 =====

# ===== ログ設定 =====

# ログレベル（DEBUG / INFO / WARNING / ERROR）
LOG_LEVEL=INFO

# ===== 常駐モード設定 =====

# 常駐モード（true=ホットキー待機してモデルをメモリに保持 / false=1回実行で終了）
RESIDENT_MODE=true

# 常駐モード時の録音開始ホットキー（pynput GlobalHotKeys 形式）
RESIDENT_HOTKEY=<ctrl>+<alt>+d

# 録音確定ホットキー（貼付+送信）
CONFIRM_HOTKEY=<ctrl>+<alt>+d

# 録音確定ホットキー（貼付のみ）
CONFIRM_PASTE_ONLY_HOTKEY=<ctrl>+<alt>+v

# 録音キャンセルホットキー
CANCEL_HOTKEY=<ctrl>+<alt>+q

# コピーのみホットキー（クリップボードにコピーするだけで貼り付けない）
COPY_ONLY_HOTKEY=<ctrl>+<alt>+c

# 録音の一時停止/再開ホットキー
PAUSE_HOTKEY=<ctrl>+<alt>+z

# 貼付から送信(Enter)までの待機秒数（Claudeなどペースト直後のEnterが効かないアプリ向け）
PASTE_ENTER_DELAY=0.5

# ===== AI送信設定 =====

# AI送信アプリ（Edge PWA）の設定（複数設定可、番号は1始まり）
# Edge で「アプリとしてインストール」したページのURLを指定する
# AI_SEND_1_NAME=ChatGPT
# AI_SEND_1_URL=https://chatgpt.com
# AI_SEND_2_NAME=Google AI
# AI_SEND_2_URL=https://gemini.google.com/app

# アプリ起動後の待機秒数（起動が遅い場合は増やす）
AI_SEND_DELAY=2.5

# 1番目のAIアプリへの送信ホットキー
AI_SEND_HOTKEY=<ctrl>+<alt>+a

# ===== 履歴設定 =====

# 録音WAVと文字起こしテキストを履歴に保存する
HISTORY_ENABLED=true

# 履歴の保持日数（この日数を超えた日付フォルダを自動削除）
HISTORY_RETENTION_DAYS=1

# ===== ウィンドウ設定 =====

# 常に最前面に表示する
WINDOW_TOPMOST=true

# 表示位置（center / top-left / top-right / bottom-left / bottom-right）
WINDOW_POSITION=center

# カーソルがあるモニターに表示する（デュアルモニター対応）
WINDOW_FOLLOW_CURSOR=true

# ウィンドウを表示せずトレイアイコンだけで状態表示する
WINDOW_HIDDEN=false

# 波形の感度（大きいほど小さい声でも波形が大きく振れる。デフォルト: 16）
WAVE_GAIN=4
